# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
OPENAI_MODEL=gpt-5-nano
#OPENAI_MODEL=gpt-5-mini
#OPENAI_MODEL=gpt-4o-mini
#OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Analysis Settings
LOG_LEVEL=INFO
MAX_TOKENS_PER_CHUNK=8000
CONCURRENT_FILE_WORKERS=3
DEBUG_DUMP=false
OUTPUT_DIR=./output

# Anti-hallucination Thresholds
MIN_CONFIDENCE_REASONS=2
AUTO_DOWNGRADE_HIGH_SEVERITY=true

# Repository Settings (use REPO_URL for git clone, or --repo-path CLI argument for local path)
RAG_DOCS_PATH=rag/docs
REPO_URL=
REPO_BRANCH=
REPO_COMMIT=
REFRESH_CLONE=false

# Clone behavior (used when --repo-url / REPO_URL is set)
REPO_CLONE_CACHE_DIR=.repo_cache
REPO_CLONE_TIMEOUT_SEC=180
REPO_CLONE_MAX_ATTEMPTS=2
REPO_CLONE_DEPTH=1

# Semgrep integration (leave disabled to skip static analysis)
SEMGREP_ENABLED=true
SEMGREP_BINARY=semgrep
SEMGREP_APP_TOKEN=
SEMGREP_RULES_ROOT=/semgrep-rules
SEMGREP_MAX_RULES=800
SEMGREP_TIMEOUT_SEC=180
SEMGREP_MAX_FINDINGS_PER_FILE=50
SEMGREP_INDEX_CACHE_FILE=output/semgrep_rules_index.json

# Phase 3 cross-file taint (call graph)
PHASE3_CROSS_FILE_ENABLED=false
PHASE3_CALL_GRAPH_MAX_HOPS=5
PHASE3_CALL_GRAPH_MAX_CHAINS_PER_FILE=20
